# Application URL (used by your external reverse proxy or platform)
APP_URL=https://your-domain.com

# Database (managed/external PostgreSQL recommended)
DATABASE_URL=postgresql://user:password@host:5432/cotrainer

# Backend
SECRET_KEY=change_this_to_random_32_char_string
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Generate SECRET_KEY with: openssl rand -hex 32
# Or in PowerShell: -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | ForEach-Object {[char]$_})
