# Application URL (public HTTPS URL for CORS and cookies)
APP_URL=https://cotrainer.ameri.boo

# Backend
DEBUG=false
# Optional explicit CORS list (comma-separated). Leave empty to use APP_URL.
CORS_ALLOW_ORIGINS=
SECRET_KEY=change_this_to_random_32_char_string
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Note: TLS is handled by external SWAG reverse proxy
# If using in-container nginx + certbot (--profile https):
# DOMAIN=your.domain.com
# LETSENCRYPT_EMAIL=your@email.com
# LETSENCRYPT_STAGING=0

